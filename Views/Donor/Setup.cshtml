@model BloodBridge.ViewModels.DonorProfileViewModel
@{
    ViewData["Title"] = "Setup Donor Profile";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-danger text-white text-center py-3">
                    <h4 class="mb-0 fw-bold">🩸 Setup Donor Profile</h4>
                    <small>Tell us about yourself to help match you with requests</small>
                </div>
                <div class="card-body p-4">
                    <form asp-action="Setup" method="post">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger small"></div>

                        <div class="mb-3">
                            <label asp-for="BloodType" class="form-label fw-semibold">Your Blood Type</label>
                            <select asp-for="BloodType" class="form-select form-select-lg">
                                <option value="">-- Select Blood Type --</option>
                                <option value="A+">A+</option>
                                <option value="A-">A-</option>
                                <option value="B+">B+</option>
                                <option value="B-">B-</option>
                                <option value="AB+">AB+</option>
                                <option value="AB-">AB-</option>
                                <option value="O+">O+</option>
                                <option value="O-">O-</option>
                            </select>
                            <span asp-validation-for="BloodType" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="LastDonationDate" class="form-label fw-semibold">Last Donation Date (if any)</label>
                            <input asp-for="LastDonationDate" type="date" class="form-control"
                                   max="@DateTime.Today.ToString("yyyy-MM-dd")" />
                            <div class="form-text">Leave blank if you've never donated before.</div>
                        </div>

                        <div class="mb-4 form-check form-switch">
                            <input asp-for="IsAvailable" class="form-check-input" role="switch" checked />
                            <label asp-for="IsAvailable" class="form-check-label fw-semibold">
                                I am currently available to donate
                            </label>
                        </div>

                        <button type="submit" class="btn btn-danger w-100 fw-bold py-2">
                            <i class="bi bi-heart-fill"></i> Complete Setup
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
