@model BloodBridge.ViewModels.DonationHistoryViewModel
@{
    ViewData["Title"] = "Log a Donation";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-danger text-white py-3">
                    <h5 class="mb-0 fw-bold"><i class="bi bi-plus-circle"></i> Log a Donation</h5>
                </div>
                <div class="card-body p-4">
                    <form asp-action="LogDonation" method="post">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger small"></div>

                        <div class="mb-3">
                            <label asp-for="DonationDate" class="form-label fw-semibold"></label>
                            <input asp-for="DonationDate" type="date" class="form-control"
                                   max="@DateTime.Today.ToString("yyyy-MM-dd")" />
                            <span asp-validation-for="DonationDate" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="HospitalName" class="form-label fw-semibold"></label>
                            <input asp-for="HospitalName" class="form-control" placeholder="e.g. Jinnah Hospital Karachi" />
                            <span asp-validation-for="HospitalName" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Units" class="form-label fw-semibold">Units Donated</label>
                            <input asp-for="Units" type="number" class="form-control" min="1" max="10" />
                            <span asp-validation-for="Units" class="text-danger small"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="Notes" class="form-label fw-semibold">Notes (optional)</label>
                            <textarea asp-for="Notes" class="form-control" rows="2" placeholder="Any notes..."></textarea>
                        </div>

                        <button type="submit" class="btn btn-danger w-100 fw-bold">
                            <i class="bi bi-save"></i> Save Donation
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
