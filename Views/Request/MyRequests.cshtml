@model List<BloodBridge.Models.BloodRequest>
@{
    ViewData["Title"] = "My Requests";
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h3 class="fw-bold mb-0"><i class="bi bi-list-ul text-danger"></i> My Blood Requests</h3>
        <a asp-action="Create" class="btn btn-danger btn-sm">
            <i class="bi bi-plus-circle"></i> New Request
        </a>
    </div>

    @if (!Model.Any())
    {
        <div class="text-center py-5">
            <i class="bi bi-droplet text-muted" style="font-size:4rem;"></i>
            <p class="text-muted mt-3">You haven't posted any requests yet.</p>
            <a asp-action="Create" class="btn btn-danger">Post a Request</a>
        </div>
    }
    else
    {
        @foreach (var req in Model)
        {
            <div class="card shadow-sm border-0 mb-3 @(req.IsUrgent ? "border-start border-danger border-3" : "")">
                <div class="card-body">
                    <div class="row align-items-center">
                        <div class="col-md-1 text-center">
                            <span class="badge bg-danger fs-5">@req.BloodType</span>
                        </div>
                        <div class="col-md-4">
                            <div class="fw-bold">@req.HospitalName</div>
                            <div class="text-muted small"><i class="bi bi-geo-alt"></i> @req.City &bull; @req.Quantity unit(s)</div>
                        </div>
                        <div class="col-md-2">
                            <span class="badge @(req.Status == BloodBridge.Models.RequestStatus.Open ? "bg-success" :
                                                  req.Status == BloodBridge.Models.RequestStatus.Fulfilled ? "bg-secondary" : "bg-warning text-dark")">
                                @req.Status
                            </span>
                            @if (req.IsUrgent) { <span class="badge bg-danger ms-1">URGENT</span> }
                        </div>
                        <div class="col-md-2 text-muted small">
                            <i class="bi bi-people"></i> @req.Responses.Count response(s)
                        </div>
                        <div class="col-md-2 text-muted small">
                            Deadline: @req.Deadline.ToString("dd MMM")
                        </div>
                        <div class="col-md-1 text-end">
                            <a asp-action="Details" asp-route-id="@req.Id" class="btn btn-outline-danger btn-sm">
                                <i class="bi bi-eye"></i>
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        }
    }
</div>
