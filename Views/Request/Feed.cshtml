@model List<BloodBridge.Models.BloodRequest>
@{
    ViewData["Title"] = "Blood Request Feed";
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h3 class="fw-bold mb-0"><i class="bi bi-droplet-fill text-danger"></i> Blood Request Feed</h3>
        @if (User.Identity!.IsAuthenticated)
        {
            <a asp-action="Create" class="btn btn-danger">
                <i class="bi bi-plus-circle"></i> Post a Request
            </a>
        }
    </div>

    <!-- Filters -->
    <div class="card shadow-sm border-0 mb-4">
        <div class="card-body py-3">
            <form method="get" class="row g-2 align-items-end">
                <div class="col-md-3">
                    <select name="bloodType" class="form-select form-select-sm">
                        <option value="">All Blood Types</option>
                        <option value="A+" selected="@(ViewBag.BloodType == "A+")">A+</option>
                        <option value="A-" selected="@(ViewBag.BloodType == "A-")">A-</option>
                        <option value="B+" selected="@(ViewBag.BloodType == "B+")">B+</option>
                        <option value="B-" selected="@(ViewBag.BloodType == "B-")">B-</option>
                        <option value="AB+" selected="@(ViewBag.BloodType == "AB+")">AB+</option>
                        <option value="AB-" selected="@(ViewBag.BloodType == "AB-")">AB-</option>
                        <option value="O+" selected="@(ViewBag.BloodType == "O+")">O+</option>
                        <option value="O-" selected="@(ViewBag.BloodType == "O-")">O-</option>
                    </select>
                </div>
                <div class="col-md-3">
                    <input name="city" class="form-control form-control-sm" value="@ViewBag.City" placeholder="Filter by city..." />
                </div>
                <div class="col-md-3">
                    <div class="form-check">
                        <input name="urgentOnly" type="checkbox" class="form-check-input" value="true"
                        @(ViewBag.UrgentOnly == true ? "checked" : "") />
                        <label class="form-check-label small fw-semibold">Urgent Only</label>
                    </div>
                </div>
                <div class="col-md-2">
                    <button type="submit" class="btn btn-outline-danger btn-sm w-100">
                        <i class="bi bi-funnel"></i> Filter
                    </button>
                </div>
                <div class="col-md-1">
                    <a asp-action="Feed" class="btn btn-outline-secondary btn-sm w-100">
                        <i class="bi bi-x"></i>
                    </a>
                </div>
            </form>
        </div>
    </div>

    @if (!Model.Any())
    {
        <div class="text-center py-5">
            <i class="bi bi-droplet text-muted" style="font-size:4rem;"></i>
            <p class="text-muted mt-3">No active requests found.</p>
        </div>
    }
    else
    {
        <div class="row g-3">
            @foreach (var req in Model)
            {
                <div class="col-md-4">
                    <div class="card shadow-sm h-100 @(req.IsUrgent ? "border-danger border-2" : "border-0")">
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-start mb-3">
                                <span class="badge bg-danger fs-5 px-3">@req.BloodType</span>
                                <div class="d-flex flex-column gap-1 align-items-end">
                                    @if (req.IsUrgent)
                                    {
                                        <span class="badge bg-danger">🚨 URGENT</span>
                                    }
                                    <span class="badge @(req.Status == BloodBridge.Models.RequestStatus.Open ? "bg-success" : "bg-warning text-dark") small">
                                        @req.Status
                                    </span>
                                </div>
                            </div>
                            <h6 class="fw-bold mb-1">@req.HospitalName</h6>
                            <p class="text-muted small mb-1"><i class="bi bi-geo-alt"></i> @req.City</p>
                            <p class="text-muted small mb-1"><i class="bi bi-droplet"></i> @req.Quantity unit(s) needed</p>
                            <p class="text-muted small mb-3">
                                <i class="bi bi-calendar-x @(req.Deadline < DateTime.Now ? "text-danger" : "")"></i>
                                Deadline: @req.Deadline.ToString("dd MMM yyyy")
                            </p>
                            <div class="d-flex justify-content-between align-items-center">
                                <small class="text-muted">@req.Responses.Count response(s)</small>
                                <a asp-action="Details" asp-route-id="@req.Id" class="btn btn-danger btn-sm">
                                    <i class="bi bi-eye"></i> View
                                </a>
                            </div>
                        </div>
                        <div class="card-footer text-muted small bg-transparent">
                            Posted by @req.Requester.FullName &bull; @req.CreatedAt.ToString("dd MMM")
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>
